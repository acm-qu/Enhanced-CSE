{
  "name": "enhanced-cse-wiki-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "db:up": "docker compose --profile local-db up -d postgres",
    "db:down": "docker compose --profile local-db stop postgres",
    "db:ps": "docker compose --profile local-db ps postgres",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "sync:now": "node scripts/sync-now.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
